[application]

config/name="Violet Veil"
run/main_scene="res://scenes/test_scenes/adam_testing.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

XRToolsUserSettings="*uid://bqgb8i74tm0t"
XRToolsRumbleManager="*uid://by853dk86g1qw"
GameState="*res://scripts/autoloads/GameState.gd"
LevelManager="*res://scripts/autoloads/LevelManager.gd"
DevMode="*res://scripts/autoloads/DevMode.gd"

[dotnet]

project/assembly_name="Violet Veil"

[editor_plugins]

enabled=PackedStringArray("res://addons/assetplacer/plugin.cfg", "res://addons/godot-xr-tools/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=2
rendering_device/driver.windows="d3d12"

[xr]

openxr/enabled=true
openxr/default_action_map="uid://yxmq6pk28a6o"
openxr/reference_space=2
shaders/enabled=true
